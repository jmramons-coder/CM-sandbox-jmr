  "headerDropdown": {
    "_description": "Structure of the user avatar dropdown in the app header. The role toggle lives in this dropdown.",
    "sections": [
      {
        "type": "identity",
        "fields": ["name", "email"]
      },
      {
        "type": "roleToggle",
        "label": "Role view",
        "options": [
          { "value": "assessor", "label": "Assessor" },
          { "value": "manager",  "label": "Manager"  }
        ],
        "currentValue": "dshRole",
        "onChange": "toggleDshRole()"
      },
      {
        "type": "divider"
      },
      {
        "type": "menuItem",
        "label": "Profile settings",
        "icon": "ti-settings",
        "action": "openProfileSettings()"
      },
      {
        "type": "menuItem",
        "label": "Sign out",
        "icon": "ti-logout",
        "action": "signOut()"
      }
    ]
  },

